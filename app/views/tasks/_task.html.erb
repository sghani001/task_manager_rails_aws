<div id="<%= dom_id(task) %>" class="task-card">
  <div class="task-card-header">
    <strong><%= task.title %></strong>
    <span class="status-pill"><%= task.status.humanize %></span>
  </div>

  <p class="task-description"><%= task.description %></p>

  <div class="task-card-footer">
    <% if task.duration_estimate.present? %>
      <span class="badge">Est: <%= task.duration_estimate %></span>
    <% end %>

    <%= button_to "Delete", task, method: :delete, class: "button secondary", form: { data: { turbo_confirm: "Delete this task?" } } %>
  </div>
</div>
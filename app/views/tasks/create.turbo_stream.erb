<%= turbo_stream.prepend "tasks_todo", @task %>
<%= turbo_stream.replace "new_task", partial: "tasks/form", locals: { task: Task.new } %>
<%= turbo_stream.replace "count_todo" do %>
  <span id="count_todo" class="column-tag"><%= Task.where(status: "todo", user_id: @task.user_id).count %></span>
<% end %>
<% if flash[:notice] || flash[:alert] %>
<%= turbo_stream.replace "flash-container" do %>
<div id="flash-container" class="flash-container">
  <% flash.each do |type, msg| %>
    <div id="flash_<%= type %>" class="flash <%= type %>">
      <%= msg %>
      <span class="flash-progress"></span>
    </div>
  <% end %>
</div>
<% end %>
<% end %>